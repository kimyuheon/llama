{
  "version": 4,
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows + MSVC",
      "inherits": "x64-windows-msvc-release"
    },
    {
      "name": "windows-msvc-cuda",
      "displayName": "Windows + MSVC + CUDA",
      "inherits": "x64-windows-msvc-release",
      "cacheVariables": {
        "GGML_CUDA": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "75;86;89;120",
        "CUDAToolkit_ROOT": "$penv{CUDA_PATH}",
        "CMAKE_CUDA_COMPILER": "$penv{CUDA_PATH}/bin/nvcc.exe"
      }
    },
    {
      "name": "windows-msvc-vulkan",
      "displayName": "Windows + MSVC + Vulkan",
      "inherits": "x64-windows-msvc-release",
      "environment": {
        "VULKAN_SDK": "${sourceParentDir}/VulkanSdk/Win",
        "PATH": "${sourceParentDir}/VulkanSdk/Win/Bin;$penv{PATH}"
      },
      "cacheVariables": {
        "GGML_VULKAN": "ON",
        "Vulkan_INCLUDE_DIR": "${sourceParentDir}/VulkanSdk/Win/Include",
        "Vulkan_LIBRARY": "${sourceParentDir}/VulkanSdk/Win/Lib/vulkan-1.lib"
      }
    },
    {
      "name": "linux-vulkan",
      "displayName": "Linux + Vulkan",
      "inherits": "x64-linux-gcc-release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "GGML_VULKAN": "ON"
      },
      "environment": {
        "VULKAN_SDK": "${sourceParentDir}/VulkanSdk/Linux"
      }
    },
    {
      "name": "mac-vulkan",
      "displayName": "macOS + Vulkan (MoltenVK)",
      "inherits": "arm64-apple-clang-release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "GGML_VULKAN": "ON"
      },
      "environment": {
        "VULKAN_SDK": "${sourceParentDir}/VulkanSdk/Apple"
      }
    }
  ]
}
